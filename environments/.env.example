# =============================================================================
# Application Environment — Base Configuration
# =============================================================================
# This file contains non-secret configuration values. It is committed to git
# and serves as the template for environments/.env (which is gitignored).
#
# Secrets (API keys, passwords) belong in secrets.ejson, NOT here.
# Developer overrides go in .env.local (gitignored, optional).
#
# Loading order (later overrides earlier):
#   1. .env          ← this file (base config)
#   2. .env.secrets  ← decrypted from secrets.ejson
#   3. .env.local    ← developer overrides
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Stackra"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en

# ── Server ────────────────────────────────────────────────────────────────────
# Octane is the default. FrankenPHP handles HTTP + workers in a single binary.
OCTANE_SERVER=frankenphp
OCTANE_WORKERS=auto
OCTANE_MAX_REQUESTS=1000

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=stackra
DB_USERNAME=stackra

# ── Redis (Cache, Queue, Sessions, Broadcasting) ─────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ── Object Storage (S3/R2/MinIO) ─────────────────────────────────────────────
FILESYSTEM_DISK=s3
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=stackra-dev
AWS_ENDPOINT=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM_ADDRESS="noreply@stackra.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Search ────────────────────────────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://localhost:7700

# ── Logging ───────────────────────────────────────────────────────────────────
# In production, use "stderr" so logs go to CloudWatch/Datadog.
LOG_CHANNEL=stack
LOG_LEVEL=debug
