# ==============================================================================
# Docker Environment Configuration
# ==============================================================================
# Docker infrastructure variables ONLY - no application-level configuration
# Application settings should be in .env (root directory)
#
# Usage:
#   1. Review and update values for your Docker infrastructure
#   2. Application variables go in .env, not here
#   3. Run: docker-compose -f docker/docker-compose.yml up -d
#
# Services load both files via:
#   env_file:
#     - ../environments/.env.docker  # Docker infrastructure (this file)
#     - ../.env                       # Application configuration
# ==============================================================================

# ==============================================================================
# DOCKER INFRASTRUCTURE
# ==============================================================================
# Core Docker networking and volume configuration

DOCKER_NETWORK_NAME=laravel
DOCKER_NETWORK_DRIVER=bridge
VOLUME_DRIVER=local

# ==============================================================================
# ORBSTACK DOMAIN CONFIGURATION
# ==============================================================================
# Domain suffix and service-specific domain names for OrbStack

DOMAIN_LTD=.local
APP_DOMAIN=laravel
API_DOMAIN=api

# ==============================================================================
# APPLICATION CONTAINER
# ==============================================================================
# Laravel application container configuration

# Container Settings
APP_CONTAINER_NAME=laravel-app
APP_PORT=8000
APP_RESTART_POLICY=unless-stopped

# Build Arguments
PHP_VERSION=8.4
NODE_VERSION=20
COMPOSER_VERSION=2

# Resource Limits
APP_MEMORY_LIMIT=1g
APP_CPU_LIMIT=1.0
APP_MEMORY_RESERVATION=512m
APP_CPU_RESERVATION=0.5

# Health Check
APP_HEALTHCHECK_INTERVAL=30s
APP_HEALTHCHECK_TIMEOUT=10s
APP_HEALTHCHECK_RETRIES=3

# Logging
LOG_DRIVER=json-file
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# ==============================================================================
# DATABASE - POSTGRESQL
# ==============================================================================
# PostgreSQL container configuration

# Container Settings
POSTGRES_CONTAINER_NAME=laravel-postgres
POSTGRES_DOMAIN=postgres
DB_DOMAIN=db
POSTGRES_PORT=5432

# pgAdmin Configuration
PGADMIN_CONTAINER_NAME=laravel-pgadmin
PGADMIN_DOMAIN=pgadmin
PGADMIN_PORT=5050

# ==============================================================================
# DATABASE - MYSQL (OPTIONAL)
# ==============================================================================
# MySQL container configuration

# Container Settings
MYSQL_CONTAINER_NAME=laravel-mysql
MYSQL_DOMAIN=mysql
MYSQL_PORT=3306

# phpMyAdmin Configuration
PHPMYADMIN_CONTAINER_NAME=laravel-phpmyadmin
PHPMYADMIN_DOMAIN=phpmyadmin
PHPMYADMIN_PORT=8081

# ==============================================================================
# DATABASE - MONGODB (OPTIONAL)
# ==============================================================================
# MongoDB container configuration

MONGODB_CONTAINER_NAME=laravel-mongodb
MONGODB_DOMAIN=mongodb
MONGO_DOMAIN=mongo
MONGODB_PORT=27017

# ==============================================================================
# CACHE & SESSION - REDIS
# ==============================================================================
# Redis container configuration

REDIS_CONTAINER_NAME=laravel-redis
REDIS_DOMAIN=redis
CACHE_DOMAIN=cache
REDIS_PORT=6379

# ==============================================================================
# QUEUE WORKERS
# ==============================================================================
# Queue worker container configuration

QUEUE_WORKER_REPLICAS=2
SCHEDULER_CONTAINER_NAME=laravel-scheduler

# ==============================================================================
# STORAGE - MINIO (S3-COMPATIBLE)
# ==============================================================================
# MinIO container configuration

MINIO_CONTAINER_NAME=laravel-minio
MINIO_DOMAIN=minio
S3_DOMAIN=s3
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==============================================================================
# SEARCH - MEILISEARCH
# ==============================================================================
# Meilisearch container configuration

MEILISEARCH_CONTAINER_NAME=laravel-meilisearch
MEILISEARCH_DOMAIN=meilisearch
SEARCH_DOMAIN=search
MEILISEARCH_PORT=7700

# ==============================================================================
# SEARCH - ELASTICSEARCH (OPTIONAL)
# ==============================================================================
# Elasticsearch container configuration

ELASTICSEARCH_CONTAINER_NAME=laravel-elasticsearch
ELASTICSEARCH_DOMAIN=elasticsearch
ES_DOMAIN=es
ELASTICSEARCH_PORT=9200

# ElasticVue UI
ELASTICVUE_CONTAINER_NAME=laravel-elasticvue
ELASTICVUE_DOMAIN=elasticvue
ELASTICVUE_PORT=8080

# ==============================================================================
# MAIL - MAILPIT
# ==============================================================================
# Mailpit container configuration

MAILPIT_CONTAINER_NAME=laravel-mailpit
MAILPIT_DOMAIN=mailpit
MAIL_DOMAIN=mail
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ==============================================================================
# WEBSOCKETS - LARAVEL REVERB
# ==============================================================================
# Reverb container configuration

REVERB_CONTAINER_NAME=laravel-reverb
REVERB_DOMAIN=reverb
WS_DOMAIN=ws
REVERB_PORT=6001

# ==============================================================================
# MESSAGE BROKER - KAFKA (OPTIONAL)
# ==============================================================================
# Kafka container configuration

KAFKA_CONTAINER_NAME=laravel-kafka
KAFKA_DOMAIN=kafka
KAFKA_PORT=9092

# ==============================================================================
# MESSAGE BROKER - RABBITMQ (OPTIONAL)
# ==============================================================================
# RabbitMQ container configuration

RABBITMQ_CONTAINER_NAME=laravel-rabbitmq
RABBITMQ_DOMAIN=rabbitmq
AMQP_DOMAIN=amqp
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
