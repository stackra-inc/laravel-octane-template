# =============================================================================
# Application .gitignore
# =============================================================================
# This application is a stateless deployment shell. Most runtime state is
# externalized (Redis, S3, stdout). These ignores cover local dev artifacts.
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
/vendor/
composer.lock

# ── Environment ───────────────────────────────────────────────────────────────
environments/.env
environments/.env.local
environments/.env.secrets
environments/.env.docker

# ── Runtime / Cache ───────────────────────────────────────────────────────────
/storage/
/bootstrap/cache/*.php

# ── Binaries ──────────────────────────────────────────────────────────────────
/frankenphp

# ── Build / Turbo ─────────────────────────────────────────────────────────────
.turbo/
/public/build/

# ── Testing ───────────────────────────────────────────────────────────────────
.phpunit.cache/
coverage/
coverage.xml

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.DS_Store
.idea/
*.swp
