# =============================================================================
# Bootstrap Cache
# =============================================================================
# Compiled artifacts generated by `php artisan optimize`:
#   - config.php (merged config)
#   - routes-v7.php (compiled routes)
#   - events.php (event-listener map)
#   - services.php (service provider manifest)
#   - packages.php (package auto-discovery)
#
# These are generated at build time (Docker image) or on first boot.
# Never committed — each environment generates its own.
# =============================================================================

*
!.gitignore
